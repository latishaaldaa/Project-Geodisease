# =====================================================
# TEMPLATE KONFIGURASI BACKEND - .env
# =====================================================
# File ini berisi konfigurasi untuk koneksi database
# WAJIB diisi sebelum deployment!
# =====================================================

# =====================================================
# DATABASE CONFIGURATION
# =====================================================

# UNTUK PRODUCTION (MySQL di Hosting)
# Ganti dengan kredensial MySQL hosting yang sebenarnya:
DATABASE_URL=mysql+pymysql://USERNAME:PASSWORD@HOSTNAME:3306/DATABASE_NAME

# Contoh lengkap:
# DATABASE_URL=mysql+pymysql://geodisease_user:SecurePass123@mysql.hosting.com:3306/geodisease_db

# Jika MySQL ada di server yang sama (localhost):
# DATABASE_URL=mysql+pymysql://root:password@localhost:3306/geodisease_db

# Jika MySQL pakai IP address:
# DATABASE_URL=mysql+pymysql://myuser:mypass@192.168.1.100:3306/geodisease_db

# =====================================================
# CARA MENDAPATKAN KREDENSIAL MYSQL
# =====================================================
# 1. Login ke cPanel atau Plesk hosting
# 2. Cari menu "MySQL Databases" atau "Databases"
# 3. Catat informasi berikut:
#    - USERNAME: User MySQL yang punya akses ke database
#    - PASSWORD: Password user MySQL
#    - HOSTNAME: Biasanya "localhost" atau "mysql.namahosting.com"
#    - DATABASE_NAME: Nama database yang dipakai aplikasi
#    - PORT: Biasanya 3306 (default MySQL)
# =====================================================

# =====================================================
# UNTUK DEVELOPMENT/TESTING LOKAL (SQLite)
# =====================================================
# Jika ingin test di laptop sendiri, uncomment baris ini:
# DATABASE_URL=sqlite:///ckg_database.db

# =====================================================
# FLASK CONFIGURATION (OPTIONAL)
# =====================================================
# Uncomment jika diperlukan:

# FLASK_ENV=production
# FLASK_DEBUG=False

# =====================================================
# CONTOH KONFIGURASI LENGKAP
# =====================================================
# 
# Contoh 1: MySQL di localhost
# DATABASE_URL=mysql+pymysql://geodisease_admin:AdminPass123!@localhost:3306/geodisease_db
#
# Contoh 2: MySQL di remote server
# DATABASE_URL=mysql+pymysql://dbuser:MyP@ssw0rd@mysql.example.com:3306/geo_disease
#
# Contoh 3: MySQL dengan port non-standard
# DATABASE_URL=mysql+pymysql://user:pass@host:3307/dbname
#
# =====================================================

# =====================================================
# CATATAN PENTING
# =====================================================
# 1. Pastikan user MySQL punya privilege: SELECT, INSERT, UPDATE, DELETE, CREATE, ALTER
# 2. Test koneksi MySQL sebelum deploy Docker:
#    mysql -u USERNAME -p -h HOSTNAME DATABASE_NAME
# 3. Jangan commit file .env ke Git (sudah ada di .gitignore)
# 4. Karakter khusus di password harus di-encode:
#    @ menjadi %40
#    # menjadi %23
#    $ menjadi %24
#    ! tidak perlu di-encode (biasanya)
# 5. Pastikan MySQL server bisa diakses dari Docker container
# =====================================================
